{
  "info": {
    "name": "Financial Document Management System API",
    "_postman_id": "financial-docs-api",
    "description": "Complete API collection for the FastAPI Financial Document Management System with RAG.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000/api/v1"},
    {"key": "access_token", "value": ""},
    {"key": "refresh_token", "value": ""},
    {"key": "document_id", "value": "1"}
  ],
  "item": [
    {
      "name": "🔧 Setup",
      "item": [
        {
          "name": "Seed Default Roles",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/seed-roles",
            "description": "Initialize default roles and permissions. Run this first!"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:8000/health"
          }
        }
      ]
    },
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user ID', () => pm.expect(pm.response.json().id).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@acmecorp.com\",\n  \"full_name\": \"John Doe\",\n  \"password\": \"SecurePass123\",\n  \"company\": \"Acme Corp\",\n  \"phone\": \"+1-555-0100\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('access_token', body.access_token);",
                  "pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "pm.test('Got access token', () => pm.expect(body.access_token).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@acmecorp.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👥 Roles",
      "item": [
        {
          "name": "List All Roles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/roles",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Create Custom Role",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/roles/create",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"reviewer\",\n  \"description\": \"Document reviewer with limited access\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👤 Users",
      "item": [
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/users?page=1&page_size=20", "query": [{"key":"page","value":"1"},{"key":"page_size","value":"20"}]},
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Assign Role to User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/assign-role",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"role_name\": \"analyst\"\n}"
            }
          }
        },
        {
          "name": "Get User Roles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/1/roles",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Get User Permissions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/1/permissions",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        }
      ]
    },
    {
      "name": "📄 Documents",
      "item": [
        {
          "name": "Upload Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('document_id', body.id);",
                  "pm.test('Document has ID', () => pm.expect(body.id).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/upload",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": "/path/to/your/document.pdf"},
                {"key": "title", "value": "Q4 2024 Financial Report"},
                {"key": "company_name", "value": "Acme Corp"},
                {"key": "document_type", "value": "report"},
                {"key": "description", "value": "Annual Q4 financial results"},
                {"key": "tags", "value": "quarterly,2024,revenue"}
              ]
            }
          }
        },
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?page=1&page_size=10",
              "query": [{"key":"page","value":"1"},{"key":"page_size","value":"10"}]
            },
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Search Documents (Metadata)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents/search?q=Acme&document_type=report",
              "query": [{"key":"q","value":"Acme"},{"key":"document_type","value":"report"}]
            },
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Get Document by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Update Document",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Q4 2024 Financial Report - Revised\",\n  \"tags\": \"quarterly,2024,revenue,revised\"\n}"
            }
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        }
      ]
    },
    {
      "name": "🧠 RAG / Semantic Search",
      "item": [
        {
          "name": "Index Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Chunks indexed', () => pm.expect(body.chunk_count).to.be.above(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/rag/index-document",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document_id\": {{document_id}},\n  \"force_reindex\": false\n}"
            }
          }
        },
        {
          "name": "Semantic Search",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/rag/search",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"financial risk related to high debt ratio\",\n  \"top_k\": 5,\n  \"rerank\": true\n}"
            }
          }
        },
        {
          "name": "Semantic Search (with filters)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/rag/search",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"revenue growth Q4\",\n  \"top_k\": 5,\n  \"company_filter\": \"Acme Corp\",\n  \"document_type_filter\": \"report\",\n  \"rerank\": true\n}"
            }
          }
        },
        {
          "name": "Get Document Context",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/rag/context/{{document_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Remove Document from Index",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/rag/remove-document/{{document_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        },
        {
          "name": "Vector Store Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/rag/status",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          }
        }
      ]
    }
  ]
}
